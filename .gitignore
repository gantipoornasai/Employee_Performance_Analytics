# ── Sensitive files ────────────────────────────────
.env
secrets.json
credentials.json

# ── Virtual environment ────────────────────────────
venv/
.venv/

# ── Data files (regenerated by notebooks) ──────────
data/raw/*.csv
data/processed/*.csv
data/monthly_snapshots/*.csv

# ── Model binary files (too large for GitHub) ──────
models/*.joblib
models/*.pkl

# ── Jupyter checkpoints ────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Python cache ───────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── OS files ───────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Log files ──────────────────────────────────────
*.log
automation/automation.log
automation/cron.log

# ── IDE files ──────────────────────────────────────
.vscode/
.idea/
*.swp